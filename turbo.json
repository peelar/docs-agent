{
  "$schema": "https://turborepo.com/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".eve/**", ".next/**", "!.next/cache/**", ".output/**"]
    },
    "paige#build": {
      "env": ["PAIGE_SLACK_CONNECTOR", "EVE_GATEWAY_MODEL"],
      "outputs": [".eve/**", ".vercel/output/**", ".output/**"]
    },
    "check": {
      "outputs": []
    },
    "dev": {
      "cache": false,
      "env": ["PAIGE_OPERATOR_ACCESS", "PAIGE_OPERATOR_WORKSPACE_ID"],
      "persistent": true
    },
    "dev:portless": {
      "cache": false,
      "env": ["PAIGE_OPERATOR_ACCESS", "PAIGE_OPERATOR_WORKSPACE_ID"],
      "persistent": true
    },
    "test": {
      "outputs": []
    },
    "typecheck": {
      "outputs": []
    }
  }
}
