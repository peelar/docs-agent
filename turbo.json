{
  "$schema": "https://turborepo.com/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        ".eve/**",
        ".next/**",
        "!.next/cache/**",
        ".output/**"
      ]
    },
    "docs-agent#build": {
      "dependsOn": ["^build"],
      "env": [
        "DOCS_AGENT_DATABASE_AUTH_TOKEN",
        "DOCS_AGENT_DATABASE_URL",
        "DOCS_AGENT_LINEAR_CONNECTOR",
        "DOCS_AGENT_SLACK_CONNECTOR",
        "EVE_GATEWAY_MODEL"
      ],
      "outputs": [
        ".eve/**",
        ".vercel/output/**",
        ".output/**"
      ]
    },
    "@docs-agent/control-plane#build": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "check": {
      "dependsOn": ["build"],
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "dev:portless": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["build"],
      "cache": false
    },
    "typecheck": {
      "outputs": []
    }
  }
}
