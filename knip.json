{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "rules": {
    "exports": "error",
    "types": "error",
    "nsExports": "error",
    "nsTypes": "error"
  },
  "workspaces": {
    ".": {
      "entry": [".agents/skills/*/scripts/*.{js,mjs}"]
    },
    "apps/agent": {
      "entry": [
        "agent/channels/*.ts",
        "agent/hooks/*.ts",
        "agent/instructions/*.ts",
        "agent/tools/*.ts",
        "evals/**/*.ts",
        "tests/**/*.ts"
      ]
    },
    "apps/web": {
      "ignoreIssues": {
        "components/ai-elements/**": ["exports", "types"],
        "components/ui/{badge,button-group,command,dialog,dropdown-menu,input-group,select}.tsx": [
          "exports",
          "types"
        ]
      }
    }
  }
}
